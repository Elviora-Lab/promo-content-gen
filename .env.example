# Required
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional provider overrides
AI_VISION_PROVIDER=
AI_LLM_PROVIDER=
AI_IMAGE_PROVIDER=openai
# Leave blank to use the provider's default model. Do not put "openai" or "gemini" here.
AI_VISION_MODEL=
AI_LLM_MODEL=

# Optional model overrides
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_STRATEGY_MODEL=gpt-5.4-mini
OPENAI_IMAGE_MODEL=gpt-image-2
GEMINI_MODEL=gemini-2.5-flash

# Optional. Recommended in production for CDN-backed image delivery.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
